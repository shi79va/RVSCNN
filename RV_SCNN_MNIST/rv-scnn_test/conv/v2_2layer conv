int error_check(int* test1, int* test2, int num){
    int error = 0;
    for(int i = 0; i < num; i++){
        error += abs(test1[i] - test2[i]);
    }
    return error;
}

// -----------------------------------------------------------------------------
// Accelerator conv + pool (RVSCNN)
// -----------------------------------------------------------------------------


int8_t* RVSCNN_conv_mp(int inside, int c_in, int c_out, int8_t *pInputs, int8_t *pFilters,int stride,int padding) {
    int ksize = 3; // 3x3 kernel
    int conv_out = ((inside + 2 * padding - ksize) / stride) + 1;
    int oside = ((conv_out - 2) / 2) + 1; //first 2 is for pool_size   second 2 is for pool_stride
   
    int8_t *poutputs = (int8_t *)calloc(oside * oside * c_out, sizeof(int8_t)); // final accelerator output (pooled)
     int wb_elems = conv_out * conv_out;
     int *tile_accel_out = calloc(wb_elems*c_out, sizeof(int)); // temp per-tile accel WB buffer
    // int *tile_accel_out  = (int *)malloc(conv_out * conv_out *c_out* sizeof(int));
    

    int chn_num = c_out >> 2; 
    int tile = 1 + (inside+(2*padding) - 4)/2;  // number of tiles
    int a = 0;
    //int *tile_accel_out = malloc(chn_num * tile * tile * 4 * conv_out * conv_out * sizeof(int));

    printf("tile: %d\n", tile);
    int t1 = record();
    //L_SCNN(c_in, inside, oside*oside, 0);
    L_SCNN(c_in, inside, conv_out * conv_out, 0);
    for (int i = 0; i < chn_num; i++) {
        // set mode for each of the 4 channels
        L_MODE(0, 1, 0, 1);
        L_MODE(0, 2, 0, 1);
        L_MODE(0, 3, 0, 1);
        L_MODE(0, 4, 0, 1);
       

        for (int m = 0; m < tile; m++) {
            for (int n = 0; n < tile; n++) {
                // Pack 4 output-channel filters into contiguous buffer the accelerator expects.
                // packed_filt size = 9 (kernel positions) * 4 (channels per group) * c_in (input channels)
                int packed_len = 9 * 4 * c_in;
                int8_t *packed_filt = (int8_t*)malloc(packed_len * sizeof(int8_t));
                if (!packed_filt) { fprintf(stderr, "OOM packed_filt\n"); exit(1); }

                // Layout of pFilters: for each input channel m_in, for each kernel k (0..8), for each out_ch (0..c_out-1)
                // pFilters index = (m_in*9 + k)*c_out + out_ch
                // We need packed_filt[(m_in*9 + k)*4 + ch4] = pFilters[(m_in*9 + k)*c_out + (i*4 + ch4)]
                for (int m_in = 0; m_in < c_in; m_in++) {
                    for (int kidx = 0; kidx < 9; kidx++) {
                        for (int ch4 = 0; ch4 < 4; ch4++) {
                            int out_ch = i*4 + ch4; // global output channel index
                            packed_filt[(m_in*9 + kidx)*4 + ch4] = pFilters[(m_in*9 + kidx)*c_out + out_ch];
                        }
                    }
                }

                // Call accelerator with packed filters
                SCNN4x4(packed_filt, pInputs + n*2 + m*2*inside);

                //SCNN4x4(pFilters +(i * 4), pInputs + n*2 + m*2*inside);
                RELU((int*)tile_accel_out, conv_out * conv_out);
               
                 int offset =(i * 4 * conv_out * conv_out) + (m * tile + n) * 4;
                //int offset = (i * tile * tile + (m * tile + n)) * (4 * conv_out * conv_out);

                // Write back 4 outputs
                SCNN_WB_INT(tile_accel_out + offset);
                
                POOL_RI((int8_t*)(tile_accel_out + offset));
                POOL(2); 
                // int a;

                // POOL_WB_INT(&a, 1);
                // poutputs[n + m*oside + 4*i*oside*oside] = a;

                // POOL_WB_INT(&a, 2);
                // poutputs[oside*oside + n + m*oside + 4*i*oside*oside] = a;

                // POOL_WB_INT(&a, 3);
                // poutputs[2*oside*oside + n + m*oside + 4*i*oside*oside] = a;

                // POOL_WB_INT(&a, 4);
                // poutputs[3*oside*oside + n + m*oside + 4*i*oside*oside] = a;
                 for (int ch = 0; ch < 4; ch++) {
                    int tmp = 0;
                    POOL_WB_INT(&tmp, ch+1); // retrieve pooled int result for channel (1..4)

                    // quantize immediately (clamp to int8 range)
                    if (tmp > 127) tmp = 127;
                    if (tmp < -128) tmp = -128;
                    int8_t q = (int8_t)tmp;

                    int out_ch = i*4 + ch;   // global output channel index
                    int out_tile_idx = n + m*oside; // tile position -> pooled spatial index
                    int out_index = out_ch * (oside * oside) + out_tile_idx;
                    poutputs[out_index] = q;
                }

                free(packed_filt);
               
                      
    
            }
        }
        //free(tile_accel_out);
    }
    int t2 = record();
    printf("Accelerator cycle count: %d\n", t2 - t1);
    free(tile_accel_out);
    return poutputs;
    //return temp_buffer2;
}



